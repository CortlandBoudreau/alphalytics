# Copy to backend/.env and fill in your values

# Required: shared secret between frontend and backend
API_SECRET_TOKEN=change-me-to-a-long-random-string

# Required: Anthropic API key for AI analysis
ANTHROPIC_API_KEY=sk-ant-...

# Required for Docker Compose: Redis password (also used in REDIS_URL below)
REDIS_PASSWORD=change-me-to-a-long-random-string

# Optional: Redis URL — include password if auth is enabled
# Local without Docker: redis://localhost:6379
# Local with Docker:    redis://:your-password@localhost:6379
# Railway/Upstash:      provided automatically via REDIS_URL env var
REDIS_URL=redis://localhost:6379

# Optional: comma-separated extra CORS origins
ALLOWED_ORIGINS=

# Optional: your production frontend URL (also added to CORS allowlist)
FRONTEND_URL=https://alphalytics-theta.vercel.app
